set -euo pipefail

if [[ -t 2 ]] && command -v tput >/dev/null 2>&1; then
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    YELLOW=$(tput setaf 3)
    BLUE=$(tput setaf 4)
    NC=$(tput sgr0)
else
    RED=""; GREEN=""; YELLOW=""; BLUE=""; NC=""
fi

XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-${HOME}/.cache}"
XDG_STATE_HOME="${XDG_STATE_HOME:-${HOME}/.local/state}"

DOTFILES_DIR="${DOTFILES_DIR:-${HOME}/.dotfiles}"
BACKUP_DIR="${BACKUP_DIR:-${XDG_STATE_HOME}/dotfiles-backup}"
DRY_RUN="${DRY_RUN:-false}"

mkdir -p "${BACKUP_DIR}"

log() { echo "${GREEN}->${NC} ${1}" >&2; }
warn() { echo "${YELLOW}-> [warning]${NC} ${1}" >&2; }
die() { echo "${RED}-> [error]${NC} ${1}" >&2; exit 1; }
dry() { echo "${BLUE}-> [dry-run]${NC} ${1}" >&2; }

run() {
    if [[ ${DRY_RUN} = "true" ]]; then
        local cmd_str
        printf -v cmd_str '%q ' "${@}"
        dry "${cmd_str% }"
    else
        "${@}"
    fi
}

resolve_path() {
    if command -v realpath >/dev/null 2>&1; then
        command realpath -- "${1}" 2>/dev/null
    elif command -v python3 >/dev/null 2>&1; then
        python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "${1}"
    else
        die "realpath not available."
    fi
}

install_dotfiles() {
    local snapshot
    snapshot="$(date +%Y%m%d-%H%M%S)"

    log "installing dotfiles..."

    while IFS= read -r -d '' file; do
        local rel_path="${file#"${DOTFILES_DIR}"/}"
        local target="${HOME}/${rel_path}"
        local target_dir
        local backup_path

        target_dir="$(dirname "${target}")"
        backup_path="${BACKUP_DIR}/${snapshot}/${rel_path}"

        run mkdir -p "${target_dir}"

        if [[ -L "${target}" ]]; then
            if [[ "$(resolve_path "${target}")" = "$(resolve_path "${file}")" ]]; then
                log "already linked: ${rel_path}."
                continue
            fi

            warn "symlink points elsewhere: ${rel_path}."

            run mkdir -p "$(dirname "${backup_path}")"
            run mv "${target}" "${backup_path}"

            run ln -sfn "${file}" "${target}"

            log "relinked: ${rel_path}"
        elif [[ -e "${target}" ]]; then
            warn "backing up existing file: ${rel_path}."

            run mkdir -p "$(dirname "${backup_path}")"
            run mv "${target}" "${backup_path}"

            run ln -sfn "${file}" "${target}"
            log "linked (backed up): ${rel_path}."
        else
            run ln -sfn "${file}" "${target}"
            log "linked: ${rel_path}."
        fi
    done < <(find "${DOTFILES_DIR}" -type f -not -path "*/.git/*" -print0)

    log "installation complete. backups saved to: ${BACKUP_DIR}."
}

uninstall_dotfiles() {
    log "uninstalling dotfiles..."

    while IFS= read -r -d '' file; do
        local rel_path="${file#"${DOTFILES_DIR}"/}"
        local target="${HOME}/${rel_path}"

        if [[ -L "${target}" ]]; then
            if [[ "$(resolve_path "${target}")" = "$(resolve_path "${file}")" ]]; then
                run rm "${target}"
                log "removed symlink: ${rel_path}."
            else
                log "skipping: ${rel_path} (symlink points elsewhere)."
            fi
        else
            log "skipping: ${rel_path} (not a symlink)."
        fi
    done < <(find "${DOTFILES_DIR}" -type f -not -path "*/.git/*" -print0)

    log "uninstallation complete."
}

list_dotfiles() {
    (cd "${DOTFILES_DIR}" && find . -type f -not -path "./.git/*" | sed 's|^\./||' | sort)
}

status_dotfiles() {
    while IFS= read -r -d '' file; do
        local rel_path="${file#"${DOTFILES_DIR}"/}"
        local target="${HOME}/${rel_path}"

        if [[ -L "${target}" ]]; then
            local real_target
            if real_target=$(resolve_path "${target}" 2>/dev/null); then
                if [[ "${real_target}" = "${file}" ]]; then
                    log "linked: ${rel_path}."
                else
                    log "symlink points elsewhere: ${rel_path}."
                fi
            else
                log "broken symlink: ${rel_path}"
            fi
        elif [[ -e "${target}" ]]; then
            log "exists but not linked: ${rel_path}."
        else
            log "not installed: ${rel_path}."
        fi
    done < <(find "${DOTFILES_DIR}" -type f -not -path "*/.git/*" -print0)
}

add_dotfile() {
    local file="${1}"
    local source="${HOME}/${file}"
    local target="${DOTFILES_DIR}/${file}"

    if [[ ! -e "${source}" ]]; then
        die "file not found: ${source}."
    fi

    if [[ -L "${source}" ]]; then
        local real_source
        real_source=$(resolve_path "${source}")
        if [[ "${real_source}" = "${target}" ]]; then
            die "file is already managed by dotfiles (symlink exists): ${file}."
        fi
    fi

    if [[ -e "${target}" ]] || [[ -L "${target}" ]]; then
        warn "file already exists in dotfiles: ${file}"
        if [[ "${DRY_RUN}" != "true" ]]; then
            printf "overwrite? [y/N] " >&2
            read -r
            if [[ ! "${REPLY}" =~ ^[Yy]$ ]]; then
                log "aborted"
                return
            fi
        else
            dry "would prompt to overwrite ${file} (assuming yes)"
        fi
        run rm -f "${target}"
    fi

    run mkdir -p "$(dirname "${target}")"

    if [[ -L "${source}" ]]; then
        local real_source
        real_source="$(resolve_path "${source}")"

        log "copying from symlink target: ${real_source}."
        run cp -f "${real_source}" "${target}"
    else
        run cp "${source}" "${target}"
    fi

    log "added: ${file} to dotfiles."
    git_commit "add: ${file}"
}

remove_dotfile() {
    local file="${1}"
    local target="${DOTFILES_DIR}/${file}"
    local home_file="${HOME}/${file}"

    if [[ ! -e "${target}" ]]; then
        die "dotfile not found: ${target}."
    fi

    if [[ -L "${home_file}" ]]; then
        local target_real
        local repo_real
        target_real="$(resolve_path "${home_file}" 2>/dev/null || true)"
        repo_real="$(resolve_path "${target}")"

        if [[ "${target_real}" = "${repo_real}" ]]; then
            run rm "${home_file}"
            log "removed installed symlink: ${file}."
        fi
    fi

    run rm -f "${target}"
    log "removed: ${file} from dotfiles."
    if ! restore_backup_file "${file}"; then
        warn "continuing without restoring backup"
    fi
    git_commit "removed: ${file}"
}

restore_backup() {
    if [[ ! -d "${BACKUP_DIR}" ]]; then
        die "no backup directory found at: ${BACKUP_DIR}."
    fi

    local snapshot

    snapshot="$(
        find "${BACKUP_DIR}" \
            -mindepth 1 \
            -maxdepth 1 \
            -type d \
            | sort \
            | tail -n1
    )"

    if [[ -z "${snapshot}" ]]; then
        log "no backups to restore."
        return
    fi

    log "restoring snapshot: $(basename "${snapshot}")"

    if [[ "${DRY_RUN}" != "true" ]]; then
        printf "continue? [y/N] " >&2
        read -r

        if [[ ! ${REPLY} =~ ^[Yy]$ ]]; then
            log "restore aborted."
            return
        fi
    else
        dry "would prompt for confirmation (assuming yes)"
    fi

    find "${snapshot}" -type f -print0 | while IFS= read -r -d '' backup_file; do
        local original_path
        original_path="${HOME}/${backup_file#"${snapshot}"/}"

        run mkdir -p "$(dirname "${original_path}")"

        if [[ -L "${original_path}" ]]; then
            warn "skipping managed symlink: ${original_path}"
            continue
        fi

        if [[ -e "${original_path}" ]]; then
            warn "overwriting: ${original_path}."
        fi

        run cp -a "${backup_file}" "${original_path}"

        log "restored: ${original_path}."
    done

    log "restore complete."
}

restore_backup_file() {
    local file="${1}"

    local backup_file
    backup_file="$(
        find "${BACKUP_DIR}" \
            -type f \
            -path "*/${file}" \
            | sort -r \
            | head -n1
    )"

    if [[ -f "${backup_file}" ]]; then
        run mkdir -p "$(dirname "${HOME}/${file}")"

        if [[ -e "${HOME}/${file}" ]]; then
            warn "file already exists, not restoring backup: ${file}"
            return 1
        fi

        run cp -a "${backup_file}" "${HOME}/${file}"
        log "restored: ${file}"
    else
        warn "no backup found for ${file}."
        return 1
    fi
}

require_git() {
    command -v git >/dev/null 2>&1 ||
        die "git is not installed."
}

check_git() {
    require_git

    if [[ ! -d "${DOTFILES_DIR}/.git" ]]; then
        die "not a git repository. run 'dotfiles git-init' first."
    fi
}

git_init() {
    require_git

    if [[ -d "${DOTFILES_DIR}/.git" ]]; then
        die "git repository already exists in ${DOTFILES_DIR}."
    fi

    (cd "${DOTFILES_DIR}" && git init)
    log "initialised empty git repository in ${DOTFILES_DIR}."
}

git_status() {
    check_git
    (cd "${DOTFILES_DIR}" && git status)
}

git_log() {
    check_git
    (cd "${DOTFILES_DIR}" && git log --oneline --graph --decorate "${@}")
}

git_push() {
    check_git
    (cd "${DOTFILES_DIR}" && git push -u origin HEAD)
    log "pushed to remote."
}

git_pull() {
    check_git

    (cd "${DOTFILES_DIR}" && git pull "${@}")
    log "pulled from remote."
}

git_remote() {
    check_git

    if [[ $# -eq 0 ]]; then
        (cd "${DOTFILES_DIR}" && git remote -v)
    else
        (cd "${DOTFILES_DIR}" && git remote "${@}")
    fi
}

git_diff() {
    check_git

    (cd "${DOTFILES_DIR}" && git diff "${@}")
}

git_commit() {
    check_git
    local message="${1:-update dotfiles}"

    if [[ "${DRY_RUN}" = "true" ]]; then
        dry "git add . && git commit -m ${message}"
    else
        if [[ -d "${DOTFILES_DIR}/.git" ]]; then
            (
                cd "${DOTFILES_DIR}"
                git add .
                if ! git diff --cached --quiet; then
                    git commit -m "${message}"
                fi
            )
        fi
    fi
}

show_config() {
    local managed_count
    managed_count=$(find "${DOTFILES_DIR}" -type f -not -path "*/.git/*" | wc -l)
    local backup_count
    backup_count=$(find "${BACKUP_DIR}" -type f 2>/dev/null | wc -l | tr -d ' ')
    local git_repo
    if [[ -d "${DOTFILES_DIR}"/.git ]]; then
        git_repo="${GREEN}yes${NC}"
    else
        git_repo="${RED}no${NC}"
    fi

    cat << EOF
${GREEN}->${NC} Dotfiles Manager Configuration:
    DOTFILES_DIR:       ${DOTFILES_DIR}
    BACKUP_DIR:         ${BACKUP_DIR}
    XDG_CONFIG_HOME:    ${XDG_CONFIG_HOME}
    XDG_STATE_HOME:     ${XDG_STATE_HOME}

Managed files:  ${GREEN}${managed_count}${NC}
Backup count:   ${GREEN}${backup_count}${NC}
Git repo:       ${git_repo}
EOF
}

help() {
    cat >&2 << EOF
Dotfiles Manager

Usage: dotfiles <command> [arguments]

XDG Directories:
    Home:           ${HOME}
    Dotfiles:       ${DOTFILES_DIR}
    Backups:        ${BACKUP_DIR}
    Config:         ${XDG_CONFIG_HOME}/dotfiles/
    State:          ${XDG_STATE_HOME}/dotfiles/

Environment Variables:
    DOTFILES_DIR                - Override dotfiles location (default: ~/.dotfiles)
    BACKUP_DIR                  - Override backup location
    XDG_CONFIG_HOME             - XDG config home (default: ~/.config)
    XDG_STATE_HOME              - XDG state home (default: ~/.local/state)

Commands:
    install                     - Create symlinks for all dotfiles.
    uninstall                   - Remove symlinks from home directory.
    list                        - List all managed dotfiles.
    status                      - Show installation status of dotfiles.
    add <file>                  - Add a new file to dotfiles management.
    remove <file>               - Remove a file from dotfiles management.
    restore                     - Restore backed up files.
    sync                        - Sync changes between home and dotfiles repo.
    save                        - Commit changes to git.
    config                      - Shows config.

Git Commands:
    git-init                    - Initialise git repository.
    git-status                  - Show git status.
    git-commit [message]        - Commit changes.
    git-log [options]           - Show commit history.
    git-push                    - Push to remote.
    git-pull [args]             - Pull from remote.
    git-diff [options]          - Show differences.

Options:
    [--dry-run] [-n]            - Preview changes without executing.
    [--help] [-h]               - Show this help.
    [--version] [-v]            - Show version information.

EOF
}

version() {
    echo "dotfiles version 0.4.1"
}

args() {
    if [[ $# -eq 0 ]]; then
        help
        die "no command specified"
    fi

    local action=""
    local action_args=()

    while [[ $# -gt 0 ]]; do
        case "${1}" in
            --dry-run|-n)
                DRY_RUN="true"
                shift
            ;;
            --help|-h)
                help
                exit 0
            ;;
            --version|-v)
                version
                exit 0
            ;;
            *)
                if [[ -z "${action}" ]]; then
                    action="${1}"
                    shift
                else
                    action_args+=("${1}")
                    shift
                fi
            ;;
        esac
    done

    if [[ -z "${action}" ]]; then
        help
        die "no command specified."
    fi

    case "${action}" in
        i|install) install_dotfiles ;;
        u|uninstall) uninstall_dotfiles ;;
        l|list) list_dotfiles ;;
        s|status) status_dotfiles ;;
        a|add)
            if [[ ${#action_args[@]} -eq 0 ]]; then
                die "missing argument. usage: ./dotfiles add <file>"
            fi
            add_dotfile "${action_args[0]}"
        ;;
        rm|remove)
            if [[ ${#action_args[@]} -eq 0 ]]; then
                die "missing argument. usage: ./dotfiles remove <file>"
            fi
            remove_dotfile "${action_args[0]}"
        ;;
        r|restore) restore_backup ;;
        config) show_config ;;

        git-init) git_init ;;
        git-status) git_status ;;
        git-log) git_log "${action_args[@]}" ;;
        git-push) git_push ;;
        git-pull) git_pull "${action_args[@]}" ;;
        git-remote) git_remote "${action_args[@]}" ;;
        git-diff) git_diff "${action_args[@]}" ;;
        git-commit|commit|save) git_commit "${action_args[0]:-save dotfiles}" ;;

        sync)
            if [[ "${DRY_RUN}" = "true" ]]; then
                dry "full sync cycle (git_pull-> install_dotfiles -> git_push)"
            else
                check_git
                if git -C "${DOTFILES_DIR}" remote get-url origin >/dev/null 2>&1; then
                    git_pull
                fi
                install_dotfiles
                if git -C "${DOTFILES_DIR}" remote get-url origin >/dev/null 2>&1; then
                    git_push
                fi
            fi
        ;;
        h|help) help;;
        v|version) version ;;
        *)
            help
            die "unknown command: ${action}."
        ;;
    esac
}

main() {
    if [[ ! -d "${DOTFILES_DIR}" ]]; then
        warn "dotfiles directory not found in: ${DOTFILES_DIR}"
        printf "create it now? [y/N] " >&2
        read -r

        if [[ "${REPLY}" =~ ^[Yy]$ ]]; then
            run mkdir -p "${DOTFILES_DIR}"
            log "created ${DOTFILES_DIR}."
        else
            die "dotfiles directory required."
        fi
    fi

    args "$@"
}

main "$@"
