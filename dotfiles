set -euo pipefail

XDG_DATA_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}"
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-${HOME}/.config}"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-${HOME}/.cache}"
XDG_STATE_HOME="${XDG_STATE_HOME:-${HOME}/.local/state}"

DOTFILES_DIR="${DOTFILES_DIR:-${HOME}/.dotfiles}"
BACKUP_DIR="${BACKUP_DIR:-${XDG_STATE_HOME}/dotfiles-backup}"

GIT_REMOTE="${GIT_REMOTE:-}"

mkdir -p "${BACKUP_DIR}" 2>/dev/null || true

log() {
    echo "-> ${1}" >&2
}

war() {
    echo "-> [warning] ${1}" >&2
}

die() {
    echo "-> [error] ${1}" >&2
    exit 1
}

realpath() {
    local path="${1}"
    if [ ! -e "${path}" ]; then
        echo "${path}"
        return 1
    fi

    cd "$(dirname "${path}")" && echo "$(pwd)/$(basename "${path}")"
}

install_dotfiles() {
    log "installing dotfiles..."

    find "${DOTFILES_DIR}" -type f  | while read -r file; do
        local rel_path="${file#"${DOTFILES_DIR}"/}"
        local target="${HOME}/${rel_path}"
        local target_dir

        target_dir="$(dirname "${target}")"

        mkdir -p "${target_dir}"

        if [ -L "${target}" ] && [ "$(realpath "${target}")" = "${file}" ]; then
            log "already linked: ${rel_path}."
        elif [ -e "${target}" ]; then
            war "backing up existing file: ${rel_path}."
            local backup_path

            backup_path="${BACKUP_DIR}/$(dirname "${rel_path}")"
            mkdir -p "${backup_path}"
            mv "${target}" "${BACKUP_DIR}/${rel_path}"
            ln -s "${file}" "${target}"
            log "linked (backed up): ${rel_path}."
        else
            ln -s "${file}" "${target}"
            log "linked: ${rel_path}."
        fi
    done

    log "installation complete. backups saved to: ${BACKUP_DIR}."
}

uninstall_dotfiles() {
    log "uninstalling dotfiles..."

    find "${DOTFILES_DIR}" -type f | while read -r file; do
        local rel_path="${file#"${DOTFILES_DIR}"/}"
        local target="${HOME}/${rel_path}"

        if [ -L "${target}" ]; then
            local link_target
            link_target="$(realpath "${target}")"

            if [ "${link_target}" = "${file}" ]; then
                rm "${target}"
                log "removed symlink: ${rel_path}."

                local target_dir
                target_dir="$(dirname "${target}")"
                rmdir "${target_dir}" 2>/dev/null || true
            else
                log "skipping: ${rel_path} (symlink points elsewhere)."
            fi
        else
            log "skipping: ${rel_path} (not a symlink)."
        fi
    done

    log "uninstallation complete."
}

list_dotfiles() {
    (cd "${DOTFILES_DIR}" && find . -type f | sed 's|^\./||' | sort)
}

status_dotfiles () {
    find "${DOTFILES_DIR}" -type f | while read -r file; do
        local rel_path="${file#"${DOTFILES_DIR}"/}"
        local target="${HOME}/${rel_path}"

        if [ -L "${target}" ] && [ "$(realpath "${target}")" = "${file}" ]; then
            log "linked: ${rel_path}."
        elif [ -f "${target}" ]; then
            log "exists but not linked: ${rel_path}."
        else
            log "not installed: ${rel_path}."
        fi
    done
}

add_dotfile() {
    local file="${1}"
    local source="${HOME}/${file}"
    local target="${DOTFILES_DIR}/${file}"

    if [ ! -e "${source}" ]; then
        die "file not found: ${source}."
    fi

    if [ -L "${source}" ] && [ "$(realpath "${source}")" = "${target}" ] ; then
        die "file is already managed by dotfiles (symlink exists): ${file}."
    fi

    if [ -e "${target}" ] || [ -L "${target}" ]; then
        war "file already exists in dotfiles: ${file}"
        read -p "overwrite? [y/N] " -r
        if [[ ! "${REPLY}" =~ ^[Yy]$ ]]; then
            log aborted
            return
        fi
        rm -f "${target}"
    fi

    mkdir -p "$(dirname "${target}")"

    if [ -L "${source}" ] ; then
        local real_source
        real_source="$(realpath "${source}")"

        log "copying from symlink target: ${real_source}."
        cp -f "${real_source}" "${target}"
    else
        cp "${source}" "${target}"
    fi

    log "added: ${file} to dotfiles."
    auto_commit "add: ${file}"
}

remove_dotfile() {
    local file="${1}"
    local target="${DOTFILES_DIR}/${file}"

    if [ ! -e "${target}" ]; then
        die "dotfile not found: ${target}."
    fi

    rm -f "${target}"
    log "removed: ${file} from dotfiles."
    auto_commit "removed: ${file}"
}

restore_backup () {
    if [ ! -d "${BACKUP_DIR}" ]; then
        die "no backup directory found at: ${BACKUP_DIR}."
    fi

    local file_count
    file_count="$(find "${BACKUP_DIR}" -type f | wc -l)"

    if [ "${file_count}" -eq 0 ]; then
        log "no files to restore."
        return
    fi

    log "found ${file_count} backed up files."
    war "this will overwrite any existing files in your home directory."
    read -p "continue? [y/N] " -r
    if [[ ! ${REPLY} =~ ^[Yy]$ ]]; then
        log "restore aborted."
        return
    fi

    find "${BACKUP_DIR}" -type f | while read -r backup_file; do
        local original_path="${HOME}/${backup_file#"${BACKUP_DIR}"/}"
        local original_dir
        original_dir="$(dirname "${original_path}")"

        mkdir -p "${original_dir}"

        if [ -e "${original_path}" ]; then
            war "overwriting: ${original_path}."
        fi

        cp "${backup_file}" "${original_path}"
        log "restored: ${original_path}."
    done

    log "restore complete."
}

check_git() {
    if [ ! -d "${DOTFILES_DIR}/.git" ]; then
        die "not a git repository. run 'dotfiles git-init' first."
    fi
}

git_init() {
    if [ -d "${DOTFILES_DIR}/.git" ]; then
        die "git repository already exists in ${DOTFILES_DIR}."
    fi

    (cd "${DOTFILES_DIR}" && git init)
    log "initialised empty git respository in ${DOTFILES_DIR}."
}

git_status() {
    check_git
    (cd "${DOTFILES_DIR}" && git status)
}

git_log() {
    check_git
    (cd "${DOTFILES_DIR}" && git log --oneline --graph --decorate "${@}")
}

git_push() {
    check_git

    if [ -z "${GIT_REMOTE}" ]; then
        die "no remote configured. set GIT_REMOTE environment variable or configure manually."
    fi

    (cd "${DOTFILES_DIR}" && git push "${GIT_REMOTE}" "${@:-origin main}")
    log "pushed to remote."
}

git_pull() {
    check_git

    (cd "${DOTFILES_DIR}" && git pull "${@}")
    log "pulled from remote."
}

git_remote() {
    check_git

    if [ $# -eq 0 ]; then
        (cd "${DOTFILES_DIR}" && git remote -v)
    else
        (cd "${DOTFILES_DIR}" && git remote "${@}")
    fi
}

git_diff() {
    check_git

    (cd "${DOTFILES_DIR}" && git diff "${@}")
}

git_commit() {
    check_git
    local message="${1:-update dotfiles}"

    (cd "${DOTFILES_DIR}" && git add . && git commit -m "${message}")
    log "committed: ${message}"
}

auto_commit() {
    local message="${1}"

    if [ -d "${DOTFILES_DIR}/.git" ]; then
        (cd "${DOTFILES_DIR}" && git add . && git commit -m "${message}" 2>/dev/null || true)
    fi
}

sync_to_dotfiles(){
    log "syncing changes from home to dotfiles..."

    find "${DOTFILES_DIR}" -type f | while read -r file; do
        local rel_path="${file#"${DOTFILES_DIR}"/}"
        local source="${HOME}/${rel_path}"

        if [ ! -e "${source}" ]; then
            war "home file missing: ${rel_path} (skipping)"
            continue
        fi

        if [ -f "${source}" ]; then
            if [ -L "${source}" ]; then
                cp "$(realpath "${source}")" "${file}"
            else
                cp "${source}" "${file}"
            fi
            log "synced: ${rel_path}"
        fi
    done

    log "sync complete."
    auto_commit "sync from home"
}

help() {
    cat >&2 << EOF
Dotfiles Manager

Usage: dotfiles <command> [arguments]

XDG Directories:
    Home:           ${HOME}
    Dotfiles:       ${DOTFILES_DIR}
    Backups:        ${BACKUP_DIR}
    Config:         ${XDG_CONFIG_HOME}/dotfiles/
    State:          ${XDG_STATE_HOME}/dotfiles/

Environment Variables:
    DOTFILES_DIR                - Override dotfiles location (default: ~/.dotfiles)
    BACKUP_DIR                  - Override backup location
    GIT_REMOTE                  - Default git remote for push/pull
    XDG_CONFIG_HOME             - XDG config home (default: ~/.config)
    XDG_STATE_HOME              - XDG state home (default: ~/.local/state)

Commands:
    install                     - Create symlinks for all dotfiles.
    uninstall                   - Remove symlinks from home directory.
    list                        - List all managed dotfiles.
    status                      - Show installation status of dotfiles.
    add <file>                  - Add a new file to dotfiles management.
    remove <file>               - Remove a file from dotfiles management.
    restore                     - Restore backed up files.
    sync                        - Sync changes between home and dotfiles repo.
    save                        - Commit changes to git.

Git Commands:
    git-init                    - Initialise git repository.
    git-status                  - Show git status.
    git-commit [message]        - Commit changes.
    git-log [options]           - Show commit history.
    git-push [remote]           - Push to remote.
    git-pull [remote]           - Pull from remote.
    git-diff [options]          - Show differences.

Options:
    [--help] [-h]               - Show this help.
    [--version] [-v]            - Show version information.

EOF
}

version() {
    echo "dotfiles version 0.1.0"
}

args() {
    if [ $# -eq 0 ]; then
        help
        die "no command specified"
    fi

    action="${1}"
    shift

    case $action in
        i|install) install_dotfiles ;;
        u|uninstall) uninstall_dotfiles ;;
        l|list) list_dotfiles ;;
        s|status) status_dotfiles ;;
        a|add)
            if [ $# -eq 0 ]; then
                die "missing argument." "usage: ./dotfiles add <file>"
            fi
            add_dotfile "${1}"
        ;;
        rm|remove)
            if [ $# -eq 0 ]; then
                die "missing argument." "usage: ./dotfiles remove <file>"
            fi
            remove_dotfile "${1}"
        ;;
        r|restore) restore_backup ;;

        git-init) git_init ;;
        git-status) git_status ;;
        git-log) git_log "${@}" ;;
        git-push) git_push "${@}" ;;
        git-pull) git_pull "${@}" ;;
        git-remote) git_remote "${@}" ;;
        git-diff) git_diff "${@}" ;;
        git-commit|commit|save) git_commit "${2:-save dotfiles}" ;;

        sync)
            git_pull
            sync_to_dotfiles
            git_push
            install_dotfiles
        ;;
        h|help|--help|-h) help;;
        v|version|--version|-v) version ;;
        *)
            help
            die "unknown command: ${action}."
        ;;
    esac
}

main() {
    if [[ ! -d "${DOTFILES_DIR}" ]]; then
        war "dotfiles directory not found in: ${DOTFILES_DIR}"
        read -p "create it now? [y/N] " -r
        if [[ "${REPLY}" =~ ^[Yy]$ ]]; then
            mkdir -p "${DOTFILES_DIR}"
            log "created ${DOTFILES_DIR}."
        else
            die "dotfiles directory required."
        fi
    fi

    args "$@"
}

main "$@"
